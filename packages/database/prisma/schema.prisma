generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Matter {
  id          String    @id @default(uuid()) @db.Uuid
  matter_id   String    @unique
  title       String
  description String
  matter_type String
  status      String
  stage       String?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  closed_at   DateTime?
  archived_at DateTime?

  clients         Client[]
  materials       Material[]
  evidence        Evidence[]
  fact_drafts     FactDraft[]
  facts           Fact[]
  issue_drafts    IssueDraft[]
  issues          Issue[]
  law_drafts      LawDraft[]
  laws            Law[]
  argument_drafts ArgumentDraft[]
  arguments       Argument[]
  document_drafts DocumentDraft[]
  documents       Document[]
  tasks           Task[]
  timelines       Timeline[]
  workflow_events WorkflowEvent[]
  ai_records      AiRecord[]
  knowledge       Knowledge[]
  workspaces      Workspace[]

  @@map("matters")
}

model Client {
  id           String   @id @default(uuid()) @db.Uuid
  client_id    String   @unique
  matter_id    String
  name         String
  client_type  String
  contact_info Json
  status       String
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  matter Matter @relation(fields: [matter_id], references: [matter_id], onDelete: Restrict, onUpdate: Cascade)
  tasks  Task[]

  @@index([matter_id], map: "idx_clients_matter_id")
  @@map("clients")
}

model Material {
  id          String   @id @default(uuid()) @db.Uuid
  material_id String   @unique
  matter_id   String
  title       String
  material_type String
  source      String
  storage_uri String
  status      String
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  matter    Matter      @relation(fields: [matter_id], references: [matter_id], onDelete: Restrict, onUpdate: Cascade)
  evidence  Evidence[]
  documents Document[]
  tasks     Task[]
  timelines Timeline[]
  ai_records AiRecord[]
  knowledge Knowledge[]
  workspaces Workspace[]

  @@index([matter_id], map: "idx_materials_matter_id")
  @@map("materials")
}

model Evidence {
  id            String   @id @default(uuid()) @db.Uuid
  evidence_id   String   @unique
  matter_id     String
  material_id   String
  title         String
  evidence_type String
  description   String
  relevance     String
  status        String
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  matter      Matter      @relation(fields: [matter_id], references: [matter_id], onDelete: Restrict, onUpdate: Cascade)
  material    Material    @relation(fields: [material_id], references: [material_id], onDelete: Restrict, onUpdate: Cascade)
  documents   Document[]
  tasks       Task[]
  timelines   Timeline[]
  workflow_events WorkflowEvent[]
  ai_records  AiRecord[]
  knowledge   Knowledge[]
  workspaces  Workspace[]
  fact_evidences FactEvidence[]

  @@index([matter_id], map: "idx_evidence_matter_id")
  @@index([material_id], map: "idx_evidence_material_id")
  @@map("evidence")
}

model Document {
  id           String   @id @default(uuid()) @db.Uuid
  document_id  String   @unique
  matter_id    String
  material_id  String?
  evidence_id  String?
  argument_id  String?
  title        String
  document_type String
  version      String
  content_uri  String?
  content      String?
  status       String
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  matter      Matter     @relation(fields: [matter_id], references: [matter_id], onDelete: Restrict, onUpdate: Cascade)
  material    Material?  @relation(fields: [material_id], references: [material_id], onDelete: Restrict, onUpdate: Cascade)
  evidence    Evidence?  @relation(fields: [evidence_id], references: [evidence_id], onDelete: Restrict, onUpdate: Cascade)
  argument    Argument?  @relation(fields: [argument_id], references: [argument_id], onDelete: Restrict, onUpdate: Cascade)
  arguments   DocumentArgument[]
  facts       DocumentFact[]
  issues      DocumentIssue[]
  laws        DocumentLaw[]
  tasks       Task[]
  timelines   Timeline[]
  workflow_events WorkflowEvent[]
  ai_records  AiRecord[]
  knowledge   Knowledge[]
  workspaces  Workspace[]

  @@index([matter_id], map: "idx_documents_matter_id")
  @@index([material_id], map: "idx_documents_material_id")
  @@index([evidence_id], map: "idx_documents_evidence_id")
  @@index([argument_id], map: "idx_documents_argument_id")
  @@map("documents")
}

model DocumentDraft {
  id                  String    @id @default(uuid()) @db.Uuid
  matter_id           String
  document_type       String
  title               String
  content             String
  source_argument_ids Json
  source_fact_ids     Json
  source_issue_ids    Json
  source_law_ids      Json
  confidence          Float?
  ai_reasoning        String?
  review_status       String    @default("generated")
  lawyer_note         String?
  published_document_id String?
  published_at        DateTime?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  matter Matter @relation(fields: [matter_id], references: [matter_id], onDelete: Restrict, onUpdate: Cascade)

  @@index([matter_id], map: "idx_document_drafts_matter_id")
  @@index([matter_id, document_type], map: "idx_document_drafts_matter_type")
  @@index([matter_id, review_status], map: "idx_document_drafts_matter_review_status")
  @@map("document_drafts")
}

model Task {
  id          String   @id @default(uuid()) @db.Uuid
  task_id     String   @unique
  matter_id   String
  client_id   String?
  material_id String?
  evidence_id String?
  document_id String?
  title       String
  description String
  priority    String
  due_date    DateTime?
  status      String
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  matter      Matter     @relation(fields: [matter_id], references: [matter_id], onDelete: Restrict, onUpdate: Cascade)
  client      Client?    @relation(fields: [client_id], references: [client_id], onDelete: Restrict, onUpdate: Cascade)
  material    Material?  @relation(fields: [material_id], references: [material_id], onDelete: Restrict, onUpdate: Cascade)
  evidence    Evidence?  @relation(fields: [evidence_id], references: [evidence_id], onDelete: Restrict, onUpdate: Cascade)
  document    Document?  @relation(fields: [document_id], references: [document_id], onDelete: Restrict, onUpdate: Cascade)
  timelines   Timeline[]
  workflow_events WorkflowEvent[]
  ai_records  AiRecord[]
  knowledge   Knowledge[]
  workspaces  Workspace[]

  @@index([matter_id, status], map: "idx_tasks_matter_id_status")
  @@index([client_id], map: "idx_tasks_client_id")
  @@index([material_id], map: "idx_tasks_material_id")
  @@index([evidence_id], map: "idx_tasks_evidence_id")
  @@index([document_id], map: "idx_tasks_document_id")
  @@map("tasks")
}

model Timeline {
  id           String   @id @default(uuid()) @db.Uuid
  timeline_id  String   @unique
  matter_id    String
  task_id      String?
  document_id  String?
  material_id  String?
  evidence_id  String?
  ai_record_id String?
  event_type   String
  event_time   DateTime
  description  String
  source       String
  status       String
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  matter      Matter     @relation(fields: [matter_id], references: [matter_id], onDelete: Restrict, onUpdate: Cascade)
  task        Task?      @relation(fields: [task_id], references: [task_id], onDelete: Restrict, onUpdate: Cascade)
  document    Document?  @relation(fields: [document_id], references: [document_id], onDelete: Restrict, onUpdate: Cascade)
  material    Material?  @relation(fields: [material_id], references: [material_id], onDelete: Restrict, onUpdate: Cascade)
  evidence    Evidence?  @relation(fields: [evidence_id], references: [evidence_id], onDelete: Restrict, onUpdate: Cascade)
  ai_record   AiRecord?  @relation("TimelineAiRecord", fields: [ai_record_id], references: [ai_record_id], onDelete: Restrict, onUpdate: Cascade)
  workflow_events WorkflowEvent[]
  ai_records  AiRecord[] @relation("AiRecordTimeline")
  knowledge   Knowledge[]
  workspaces  Workspace[]

  @@index([matter_id, event_time], map: "idx_timelines_matter_id_event_time")
  @@map("timelines")
}

model WorkflowEvent {
  id                String   @id @default(uuid()) @db.Uuid
  workflow_event_id String   @unique
  matter_id         String
  workflow_id       String
  timeline_id       String?
  task_id           String?
  document_id       String?
  evidence_id       String?
  ai_record_id      String?
  event_type        String
  event_time        DateTime
  source            String
  payload           Json
  status            String
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  matter      Matter     @relation(fields: [matter_id], references: [matter_id], onDelete: Restrict, onUpdate: Cascade)
  timeline    Timeline?  @relation(fields: [timeline_id], references: [timeline_id], onDelete: Restrict, onUpdate: Cascade)
  task        Task?      @relation(fields: [task_id], references: [task_id], onDelete: Restrict, onUpdate: Cascade)
  document    Document?  @relation(fields: [document_id], references: [document_id], onDelete: Restrict, onUpdate: Cascade)
  evidence    Evidence?  @relation(fields: [evidence_id], references: [evidence_id], onDelete: Restrict, onUpdate: Cascade)
  ai_record   AiRecord?  @relation("WorkflowEventAiRecord", fields: [ai_record_id], references: [ai_record_id], onDelete: Restrict, onUpdate: Cascade)
  ai_records  AiRecord[]
  knowledge   Knowledge[]
  workspaces  Workspace[]

  @@index([matter_id], map: "idx_workflow_events_matter_id")
  @@index([workflow_id, event_time], map: "idx_workflow_events_workflow_id_event_time")
  @@map("workflow_events")
}

model AiRecord {
  id                String   @id @default(uuid()) @db.Uuid
  ai_record_id      String   @unique
  matter_id         String
  task_id           String?
  timeline_id       String?
  document_id       String?
  material_id       String?
  evidence_id       String?
  workflow_event_id String?
  knowledge_id      String?
  ai_task_type      String
  model             String?
  prompt_uri        String?
  result_uri        String?
  status            String
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  matter          Matter         @relation(fields: [matter_id], references: [matter_id], onDelete: Restrict, onUpdate: Cascade)
  task            Task?          @relation(fields: [task_id], references: [task_id], onDelete: Restrict, onUpdate: Cascade)
  timeline        Timeline?      @relation("AiRecordTimeline", fields: [timeline_id], references: [timeline_id], onDelete: Restrict, onUpdate: Cascade)
  timeline_owner  Timeline[]     @relation("TimelineAiRecord")
  document        Document?      @relation(fields: [document_id], references: [document_id], onDelete: Restrict, onUpdate: Cascade)
  material        Material?      @relation(fields: [material_id], references: [material_id], onDelete: Restrict, onUpdate: Cascade)
  evidence        Evidence?      @relation(fields: [evidence_id], references: [evidence_id], onDelete: Restrict, onUpdate: Cascade)
  workflow_event  WorkflowEvent? @relation(fields: [workflow_event_id], references: [workflow_event_id], onDelete: Restrict, onUpdate: Cascade)
  workflow_owner  WorkflowEvent[] @relation("WorkflowEventAiRecord")
  knowledge       Knowledge?      @relation("AiRecordToKnowledge", fields: [knowledge_id], references: [knowledge_id], onDelete: Restrict, onUpdate: Cascade)
  knowledge_links Knowledge[]     @relation("KnowledgeToAiRecord")
  workspaces      Workspace[]

  @@index([matter_id, created_at], map: "idx_ai_records_matter_id_created_at")
  @@map("ai_records")
}

model Knowledge {
  id                String   @id @default(uuid()) @db.Uuid
  knowledge_id      String   @unique
  matter_id         String
  document_id       String?
  material_id       String?
  evidence_id       String?
  task_id           String?
  timeline_id       String?
  workflow_event_id String?
  ai_record_id      String?
  title             String
  category          String
  content_uri       String
  source            String
  version           String
  status            String
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  matter         Matter         @relation(fields: [matter_id], references: [matter_id], onDelete: Restrict, onUpdate: Cascade)
  document       Document?      @relation(fields: [document_id], references: [document_id], onDelete: Restrict, onUpdate: Cascade)
  material       Material?      @relation(fields: [material_id], references: [material_id], onDelete: Restrict, onUpdate: Cascade)
  evidence       Evidence?      @relation(fields: [evidence_id], references: [evidence_id], onDelete: Restrict, onUpdate: Cascade)
  task           Task?          @relation(fields: [task_id], references: [task_id], onDelete: Restrict, onUpdate: Cascade)
  timeline       Timeline?      @relation(fields: [timeline_id], references: [timeline_id], onDelete: Restrict, onUpdate: Cascade)
  workflow_event WorkflowEvent? @relation(fields: [workflow_event_id], references: [workflow_event_id], onDelete: Restrict, onUpdate: Cascade)
  ai_record      AiRecord?      @relation("KnowledgeToAiRecord", fields: [ai_record_id], references: [ai_record_id], onDelete: Restrict, onUpdate: Cascade)
  ai_records     AiRecord[]     @relation("AiRecordToKnowledge")
  workspaces     Workspace[]

  @@index([matter_id], map: "idx_knowledge_matter_id")
  @@map("knowledge")
}

model Workspace {
  id                String   @id @default(uuid()) @db.Uuid
  workspace_id      String   @unique
  matter_id         String
  task_id           String?
  timeline_id       String?
  document_id       String?
  material_id       String?
  evidence_id       String?
  workflow_event_id String?
  ai_record_id      String?
  knowledge_id      String?
  layout            Json
  view_config       Json
  preferences       Json
  status            String
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  matter         Matter         @relation(fields: [matter_id], references: [matter_id], onDelete: Restrict, onUpdate: Cascade)
  task           Task?          @relation(fields: [task_id], references: [task_id], onDelete: Restrict, onUpdate: Cascade)
  timeline       Timeline?      @relation(fields: [timeline_id], references: [timeline_id], onDelete: Restrict, onUpdate: Cascade)
  document       Document?      @relation(fields: [document_id], references: [document_id], onDelete: Restrict, onUpdate: Cascade)
  material       Material?      @relation(fields: [material_id], references: [material_id], onDelete: Restrict, onUpdate: Cascade)
  evidence       Evidence?      @relation(fields: [evidence_id], references: [evidence_id], onDelete: Restrict, onUpdate: Cascade)
  workflow_event WorkflowEvent? @relation(fields: [workflow_event_id], references: [workflow_event_id], onDelete: Restrict, onUpdate: Cascade)
  ai_record      AiRecord?      @relation(fields: [ai_record_id], references: [ai_record_id], onDelete: Restrict, onUpdate: Cascade)
  knowledge      Knowledge?     @relation(fields: [knowledge_id], references: [knowledge_id], onDelete: Restrict, onUpdate: Cascade)

  @@index([matter_id], map: "idx_workspaces_matter_id")
  @@map("workspaces")
}

model SystemEnum {
  id         String   @id @default(uuid()) @db.Uuid
  enum_key   String
  enum_value String
  label      String
  sort_order Int      @default(0)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([enum_key, enum_value], map: "uq_system_enums_enum_key_enum_value")
  @@map("system_enums")
}

model SystemConfiguration {
  id           String   @id @default(uuid()) @db.Uuid
  config_key   String   @unique
  config_value Json
  description  String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@map("system_configurations")
}

model SystemDictionary {
  id         String   @id @default(uuid()) @db.Uuid
  dict_type  String
  dict_key   String
  dict_value String
  sort_order Int      @default(0)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([dict_type, dict_key], map: "uq_system_dictionary_type_key")
  @@map("system_dictionary")
}

model ExecutionQueueItem {
  id               String   @id @default(uuid())
  matter_id        String
  queue_id         String
  action_id        String
  work_id          String?
  slot             String
  execution_status String
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  @@unique([matter_id, queue_id], map: "uq_execution_queue_item_matter_queue")
  @@map("execution_queue_item")
}

model Fact {
  id         String   @id @default(uuid()) @db.Uuid
  fact_id    String   @unique
  matter_id  String
  title      String
  description String?
  status     String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  matter    Matter    @relation(fields: [matter_id], references: [matter_id], onDelete: Restrict, onUpdate: Cascade)
  evidences FactEvidence[]
  issues    IssueFact[]
  arguments ArgumentFact[]
  documents DocumentFact[]

  @@index([matter_id], map: "idx_facts_matter_id")
  @@map("facts")
}

model FactDraft {
  id                  String    @id @default(uuid()) @db.Uuid
  draft_id            String    @unique
  matter_id           String
  title               String
  description         String?
  confidence          Float?
  ai_reasoning        String?
  source_evidence_ids Json
  review_status       String    @default("pending")
  lawyer_note         String?
  published_fact_id   String?
  published_at        DateTime?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  matter Matter @relation(fields: [matter_id], references: [matter_id], onDelete: Restrict, onUpdate: Cascade)

  @@index([matter_id], map: "idx_fact_drafts_matter_id")
  @@index([matter_id, review_status], map: "idx_fact_drafts_matter_review_status")
  @@map("fact_drafts")
}

model FactEvidence {
  id          String   @id @default(uuid()) @db.Uuid
  fact_id     String
  evidence_id String
  note        String?
  created_at  DateTime @default(now())

  fact     Fact     @relation(fields: [fact_id], references: [fact_id], onDelete: Cascade, onUpdate: Cascade)
  evidence Evidence @relation(fields: [evidence_id], references: [evidence_id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([fact_id, evidence_id], map: "uq_fact_evidence_fact_evidence")
  @@index([fact_id], map: "idx_fact_evidence_fact_id")
  @@index([evidence_id], map: "idx_fact_evidence_evidence_id")
  @@map("fact_evidence")
}

model Issue {
  id         String   @id @default(uuid()) @db.Uuid
  issue_id   String   @unique
  matter_id  String
  title      String
  description String?
  status     String   @default("draft")
  priority   String   @default("medium")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  matter     Matter    @relation(fields: [matter_id], references: [matter_id], onDelete: Restrict, onUpdate: Cascade)
  facts      IssueFact[]
  laws       Law[]
  law_links  LawIssue[]
  arguments  Argument[]
  argument_links ArgumentIssue[]
  documents  DocumentIssue[]

  @@index([matter_id], map: "idx_issues_matter_id")
  @@map("issues")
}

model IssueDraft {
  id                 String    @id @default(uuid()) @db.Uuid
  matter_id          String
  title              String
  description        String?
  confidence         Float?
  ai_reasoning       String?
  source_fact_ids    Json
  review_status      String    @default("pending")
  lawyer_note        String?
  published_issue_id String?
  published_at       DateTime?
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  matter Matter @relation(fields: [matter_id], references: [matter_id], onDelete: Restrict, onUpdate: Cascade)

  @@index([matter_id], map: "idx_issue_drafts_matter_id")
  @@index([matter_id, review_status], map: "idx_issue_drafts_matter_review_status")
  @@map("issue_drafts")
}

model Law {
  id         String   @id @default(uuid()) @db.Uuid
  law_id     String   @unique
  matter_id  String
  issue_id   String?
  title      String
  citation   String?
  description String?
  status     String   @default("draft")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  matter Matter @relation(fields: [matter_id], references: [matter_id], onDelete: Restrict, onUpdate: Cascade)
  issue  Issue?  @relation(fields: [issue_id], references: [issue_id], onDelete: Restrict, onUpdate: Cascade)
  issues LawIssue[]
  arguments ArgumentLaw[]
  documents DocumentLaw[]

  @@index([matter_id], map: "idx_laws_matter_id")
  @@index([issue_id], map: "idx_laws_issue_id")
  @@map("laws")
}

model LawDraft {
  id                 String    @id @default(uuid()) @db.Uuid
  matter_id          String
  title              String
  citation           String?
  rule_content       String?
  application        String?
  limitations        String?
  jurisdiction       String?
  source_reference   String?
  confidence         Float?
  ai_reasoning       String?
  source_issue_ids   Json
  review_status      String    @default("pending")
  lawyer_note        String?
  published_law_id   String?
  published_at       DateTime?
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  matter Matter @relation(fields: [matter_id], references: [matter_id], onDelete: Restrict, onUpdate: Cascade)

  @@index([matter_id], map: "idx_law_drafts_matter_id")
  @@index([matter_id, review_status], map: "idx_law_drafts_matter_review_status")
  @@map("law_drafts")
}

model LawIssue {
  id         String   @id @default(uuid()) @db.Uuid
  law_id     String
  issue_id   String
  created_at DateTime @default(now())

  law   Law   @relation(fields: [law_id], references: [law_id], onDelete: Cascade, onUpdate: Cascade)
  issue Issue @relation(fields: [issue_id], references: [issue_id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([law_id, issue_id], map: "uq_law_issue_law_issue")
  @@index([law_id], map: "idx_law_issue_law_id")
  @@index([issue_id], map: "idx_law_issue_issue_id")
  @@map("law_issue")
}

model Argument {
  id          String   @id @default(uuid()) @db.Uuid
  argument_id String   @unique
  matter_id   String
  issue_id    String?
  title       String
  description String?
  conclusion  String?
  status      String
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  matter Matter   @relation(fields: [matter_id], references: [matter_id], onDelete: Restrict, onUpdate: Cascade)
  issue  Issue?   @relation(fields: [issue_id], references: [issue_id], onDelete: Restrict, onUpdate: Cascade)
  documents Document[]
  facts ArgumentFact[]
  issues ArgumentIssue[]
  laws ArgumentLaw[]
  document_links DocumentArgument[]

  @@index([matter_id], map: "idx_arguments_matter_id")
  @@index([issue_id], map: "idx_arguments_issue_id")
  @@map("arguments")
}

model ArgumentDraft {
  id                    String    @id @default(uuid()) @db.Uuid
  matter_id             String
  title                 String
  position              String?
  reasoning             String?
  counter_argument      String?
  response              String?
  risk                  String?
  conclusion            String?
  confidence            Float?
  ai_reasoning          String?
  source_fact_ids       Json
  source_issue_ids      Json
  source_law_ids        Json
  review_status         String    @default("pending")
  lawyer_note           String?
  published_argument_id String?
  published_at          DateTime?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  matter Matter @relation(fields: [matter_id], references: [matter_id], onDelete: Restrict, onUpdate: Cascade)

  @@index([matter_id], map: "idx_argument_drafts_matter_id")
  @@index([matter_id, review_status], map: "idx_argument_drafts_matter_review_status")
  @@map("argument_drafts")
}

model ArgumentFact {
  id          String   @id @default(uuid()) @db.Uuid
  argument_id String
  fact_id     String
  created_at  DateTime @default(now())

  argument Argument @relation(fields: [argument_id], references: [argument_id], onDelete: Cascade, onUpdate: Cascade)
  fact     Fact     @relation(fields: [fact_id], references: [fact_id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([argument_id, fact_id], map: "uq_argument_fact_argument_fact")
  @@index([argument_id], map: "idx_argument_fact_argument_id")
  @@index([fact_id], map: "idx_argument_fact_fact_id")
  @@map("argument_fact")
}

model ArgumentIssue {
  id          String   @id @default(uuid()) @db.Uuid
  argument_id String
  issue_id    String
  created_at  DateTime @default(now())

  argument Argument @relation(fields: [argument_id], references: [argument_id], onDelete: Cascade, onUpdate: Cascade)
  issue    Issue    @relation(fields: [issue_id], references: [issue_id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([argument_id, issue_id], map: "uq_argument_issue_argument_issue")
  @@index([argument_id], map: "idx_argument_issue_argument_id")
  @@index([issue_id], map: "idx_argument_issue_issue_id")
  @@map("argument_issue")
}

model ArgumentLaw {
  id          String   @id @default(uuid()) @db.Uuid
  argument_id String
