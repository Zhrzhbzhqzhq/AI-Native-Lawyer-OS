# Global environment template
# Copy this file to .env and fill in values for local development.

DATABASE_URL=postgresql://lawdesk:lawdesk@localhost:5432/lawdesk
POSTGRES_DB=lawdesk
POSTGRES_USER=lawdesk
POSTGRES_PASSWORD=lawdesk

NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
API_PORT=4000
AI_RUNTIME_PORT=4100
AI_MODEL_PROVIDER=openai
AI_MODEL_NAME=gpt-4o-mini
AI_API_KEY=replace_me

# AI Provider selection
# Acceptable values: mock | minimax
# Default: mock
AI_PROVIDER=mock

# MiniMax configuration (optional - only required if AI_PROVIDER=minimax)
MINIMAX_API_KEY=
# Optional: override base URL (e.g., https://api.minimaxi.com/v1)
MINIMAX_BASE_URL=
MINIMAX_MODEL=MiniMax-M3

# Notes:
# - If MINIMAX_API_KEY is not set, ProviderManager will fall back to the Mock adapter.
# - Do NOT disable fallback behavior; the system relies on a deterministic mock for stability.
