# Backend local env example
# Copy this file to .env (or .env.local) and update values for local development.
# Do NOT commit real credentials. The following are safe defaults for local Docker compose.

DATABASE_URL=postgresql://lawdesk:lawdesk@localhost:5432/lawdesk
POSTGRES_DB=lawdesk
POSTGRES_USER=lawdesk
POSTGRES_PASSWORD=lawdesk

# Backend runtime
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
API_PORT=4000

# AI runtime (example)
AI_RUNTIME_PORT=4100
AI_MODEL_PROVIDER=openai
AI_MODEL_NAME=gpt-4o-mini
AI_API_KEY=replace_me
