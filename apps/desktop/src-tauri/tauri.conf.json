{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LawDesk",
  "version": "1.0.0",
  "identifier": "com.lawdesk.desktop",
  "build": {
    "beforeDevCommand": "runtime/start-lawdesk.sh",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "pnpm --filter @lawdesk/backend build && pnpm --filter @lawdesk/frontend build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "LawDesk",
        "width": 1400,
        "height": 900
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../resources/runtime",
      "../resources/backend",
      "../resources/frontend"
    ]
  }
}