{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LawDesk",
  "version": "1.0.0",
  "identifier": "com.lawdesk.desktop",
  "build": {
    "beforeDevCommand": "runtime/start-lawdesk.sh",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "pnpm --filter @lawdesk/backend build && pnpm --filter @lawdesk/frontend build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "LawDesk",
        "width": 1400,
        "height": 900
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../resources/runtime": "runtime",
      "../resources/node-runtime": "node-runtime",
      "../resources/backend/dist": "backend/dist",
      "../resources/backend/package.json": "backend/package.json",
      "../resources/backend/node_modules/.prisma": "backend/node_modules/.prisma",
      "../resources/backend/node_modules/@fastify": "backend/node_modules/@fastify",
      "../resources/backend/node_modules/@pinojs": "backend/node_modules/@pinojs",
      "../resources/backend/node_modules/@prisma": "backend/node_modules/@prisma",
      "../resources/backend/node_modules/@lawdesk/database/package.json": "backend/node_modules/@lawdesk/database/package.json",
      "../resources/backend/node_modules/@lawdesk/database/dist": "backend/node_modules/@lawdesk/database/dist",
      "../resources/backend/node_modules/@lawdesk/database/generated/desktop-client": "backend/node_modules/@lawdesk/database/generated/desktop-client",
      "../resources/backend/node_modules/@lawdesk/database/prisma-desktop/migrations": "backend/node_modules/@lawdesk/database/prisma-desktop/migrations",
      "../resources/backend/node_modules/abstract-logging": "backend/node_modules/abstract-logging",
      "../resources/backend/node_modules/ajv": "backend/node_modules/ajv",
      "../resources/backend/node_modules/ajv-formats": "backend/node_modules/ajv-formats",
      "../resources/backend/node_modules/atomic-sleep": "backend/node_modules/atomic-sleep",
      "../resources/backend/node_modules/avvio": "backend/node_modules/avvio",
      "../resources/backend/node_modules/cookie": "backend/node_modules/cookie",
      "../resources/backend/node_modules/dotenv": "backend/node_modules/dotenv",
      "../resources/backend/node_modules/fast-content-type-parse": "backend/node_modules/fast-content-type-parse",
      "../resources/backend/node_modules/fast-decode-uri-component": "backend/node_modules/fast-decode-uri-component",
      "../resources/backend/node_modules/fast-deep-equal": "backend/node_modules/fast-deep-equal",
      "../resources/backend/node_modules/fast-json-stringify": "backend/node_modules/fast-json-stringify",
      "../resources/backend/node_modules/fast-querystring": "backend/node_modules/fast-querystring",
      "../resources/backend/node_modules/fast-uri": "backend/node_modules/fast-uri",
      "../resources/backend/node_modules/fastify": "backend/node_modules/fastify",
      "../resources/backend/node_modules/fastify-plugin": "backend/node_modules/fastify-plugin",
      "../resources/backend/node_modules/fastq": "backend/node_modules/fastq",
      "../resources/backend/node_modules/find-my-way": "backend/node_modules/find-my-way",
      "../resources/backend/node_modules/forwarded": "backend/node_modules/forwarded",
      "../resources/backend/node_modules/ipaddr.js": "backend/node_modules/ipaddr.js",
      "../resources/backend/node_modules/json-schema-ref-resolver": "backend/node_modules/json-schema-ref-resolver",
      "../resources/backend/node_modules/json-schema-traverse": "backend/node_modules/json-schema-traverse",
      "../resources/backend/node_modules/light-my-request": "backend/node_modules/light-my-request",
      "../resources/backend/node_modules/mnemonist": "backend/node_modules/mnemonist",
      "../resources/backend/node_modules/obliterator": "backend/node_modules/obliterator",
      "../resources/backend/node_modules/on-exit-leak-free": "backend/node_modules/on-exit-leak-free",
      "../resources/backend/node_modules/pino": "backend/node_modules/pino",
      "../resources/backend/node_modules/pino-abstract-transport": "backend/node_modules/pino-abstract-transport",
      "../resources/backend/node_modules/pino-std-serializers": "backend/node_modules/pino-std-serializers",
      "../resources/backend/node_modules/process-warning": "backend/node_modules/process-warning",
      "../resources/backend/node_modules/proxy-addr": "backend/node_modules/proxy-addr",
      "../resources/backend/node_modules/quick-format-unescaped": "backend/node_modules/quick-format-unescaped",
      "../resources/backend/node_modules/real-require": "backend/node_modules/real-require",
      "../resources/backend/node_modules/require-from-string": "backend/node_modules/require-from-string",
      "../resources/backend/node_modules/ret": "backend/node_modules/ret",
      "../resources/backend/node_modules/reusify": "backend/node_modules/reusify",
      "../resources/backend/node_modules/rfdc": "backend/node_modules/rfdc",
      "../resources/backend/node_modules/safe-regex2": "backend/node_modules/safe-regex2",
      "../resources/backend/node_modules/safe-stable-stringify": "backend/node_modules/safe-stable-stringify",
      "../resources/backend/node_modules/secure-json-parse": "backend/node_modules/secure-json-parse",
      "../resources/backend/node_modules/semver": "backend/node_modules/semver",
      "../resources/backend/node_modules/set-cookie-parser": "backend/node_modules/set-cookie-parser",
      "../resources/backend/node_modules/sonic-boom": "backend/node_modules/sonic-boom",
      "../resources/backend/node_modules/split2": "backend/node_modules/split2",
      "../resources/backend/node_modules/thread-stream": "backend/node_modules/thread-stream",
      "../resources/backend/node_modules/toad-cache": "backend/node_modules/toad-cache",
      "../resources/frontend": "frontend"
    }
  }
}
