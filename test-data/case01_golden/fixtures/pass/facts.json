{
  "facts": [
    {
      "fact_id": "fact_001",
      "description": "张建国为本案出借人。",
      "source_evidence": ["ev_001", "ev_009"]
    },
    {
      "fact_id": "fact_002",
      "description": "李海涛为本案借款人。",
      "source_evidence": ["ev_001", "ev_009"]
    },
    {
      "fact_id": "fact_003",
      "description": "张建国与李海涛系多年朋友。",
      "source_evidence": ["ev_001"]
    },
    {
      "fact_id": "fact_004",
      "description": "李海涛于 2023 年 5 月因餐饮店经营周转需要向张建国借款。",
      "source_evidence": ["ev_001", "ev_003", "ev_004", "ev_009"]
    },
    {
      "fact_id": "fact_005",
      "description": "李海涛在微信中主动提出借款 200000 元。",
      "source_evidence": ["ev_003"]
    },
    {
      "fact_id": "fact_006",
      "description": "借款用途包括餐饮店房租、供货款和员工工资。",
      "source_evidence": ["ev_004"]
    },
    {
      "fact_id": "fact_007",
      "description": "张建国要求李海涛出具借条并明确金额、期限和利息。",
      "source_evidence": ["ev_004"]
    },
    {
      "fact_id": "fact_008",
      "description": "李海涛同意按月利率 1% 计算利息。",
      "source_evidence": ["ev_004", "ev_009", "ev_014"]
    },
    {
      "fact_id": "fact_009",
      "description": "双方确认还款期限为 2023-11-10。",
      "source_evidence": ["ev_004", "ev_009"]
    },
    {
      "fact_id": "fact_010",
      "description": "李海涛提供了本人银行账户作为收款账户。",
      "source_evidence": ["ev_004", "ev_010"]
    },
    {
      "fact_id": "fact_011",
      "description": "张建国于 2023-05-10 通过银行转账向李海涛支付 200000 元。",
      "source_evidence": ["ev_005", "ev_010"]
    },
    {
      "fact_id": "fact_012",
      "description": "2023-05-10 转账备注为“借款”。",
      "source_evidence": ["ev_010"]
    },
    {
      "fact_id": "fact_013",
      "description": "李海涛于 2023-05-10 确认收到 200000 元。",
      "source_evidence": ["ev_005"]
    },
    {
      "fact_id": "fact_014",
      "description": "李海涛于 2023-05-10 向张建国出具借条。",
      "source_evidence": ["ev_005", "ev_009"]
    },
    {
      "fact_id": "fact_015",
      "description": "张建国持有借条原件。",
      "source_evidence": ["ev_002"]
    },
    {
      "fact_id": "fact_016",
      "description": "借条载明借款本金为 200000 元。",
      "source_evidence": ["ev_009"]
    },
    {
      "fact_id": "fact_017",
      "description": "借条载明借款期限自 2023-05-10 起至 2023-11-10 止。",
      "source_evidence": ["ev_009"]
    },
    {
      "fact_id": "fact_018",
      "description": "借条载明借款利息按月利率 1% 计算。",
      "source_evidence": ["ev_009"]
    },
    {
      "fact_id": "fact_019",
      "description": "借条约定逾期实现债权的合理费用由借款人承担。",
      "source_evidence": ["ev_009"]
    },
    {
      "fact_id": "fact_020",
      "description": "李海涛于 2023-08-20 向张建国归还 20000 元。",
      "source_evidence": ["ev_011"]
    },
    {
      "fact_id": "fact_021",
      "description": "2023-08-20 还款备注为“还款”。",
      "source_evidence": ["ev_011"]
    },
    {
      "fact_id": "fact_022",
      "description": "张建国确认 2023-08-20 的 20000 元用于偿还本案借款本金。",
      "source_evidence": ["ev_011"]
    },
    {
      "fact_id": "fact_023",
      "description": "2023-08-20 后剩余本金为 180000 元。",
      "source_evidence": ["ev_007", "ev_011", "ev_013"]
    },
    {
      "fact_id": "fact_024",
      "description": "2023-08-21 至 2024-03-10 张建国未再收到李海涛支付的本案款项。",
      "source_evidence": ["ev_012"]
    },
    {
      "fact_id": "fact_025",
      "description": "张建国陈述双方之间不存在其他共同投资、买卖或劳务结算关系。",
      "source_evidence": ["ev_016"]
    },
    {
      "fact_id": "fact_026",
      "description": "2023-11-10 借款到期。",
      "source_evidence": ["ev_004", "ev_009"]
    },
    {
      "fact_id": "fact_027",
      "description": "2023-11-11 张建国通过微信提醒李海涛借款已到期并要求还款。",
      "source_evidence": ["ev_006"]
    },
    {
      "fact_id": "fact_028",
      "description": "李海涛在 2023-11-11 请求宽限到 2023 年 12 月底。",
      "source_evidence": ["ev_006"]
    },
    {
      "fact_id": "fact_029",
      "description": "2023-12-28 李海涛在微信中承认本金还欠 180000 元。",
      "source_evidence": ["ev_007"]
    },
    {
      "fact_id": "fact_030",
      "description": "李海涛承诺 2024-01-15 前先处理一部分欠款。",
      "source_evidence": ["ev_008"]
    },
    {
      "fact_id": "fact_031",
      "description": "2024-01-15 李海涛未按承诺付款。",
      "source_evidence": ["ev_008"]
    },
    {
      "fact_id": "fact_032",
      "description": "2024-02-07 李海涛再次承认尚欠 180000 元本金和利息。",
      "source_evidence": ["ev_008"]
    },
    {
      "fact_id": "fact_033",
      "description": "李海涛承诺 2024-02-08 前想办法转款。",
      "source_evidence": ["ev_008"]
    },
    {
      "fact_id": "fact_034",
      "description": "2024-02-09 张建国确认未收到李海涛还款。",
      "source_evidence": ["ev_008"]
    },
    {
      "fact_id": "fact_035",
      "description": "2024-02-20 电话中李海涛承认原始借款为 200000 元。",
      "source_evidence": ["ev_013"]
    },
    {
      "fact_id": "fact_036",
      "description": "2024-02-20 电话中李海涛承认已还 20000 元。",
      "source_evidence": ["ev_013"]
    },
    {
      "fact_id": "fact_037",
      "description": "2024-02-20 电话中李海涛承认剩余本金为 180000 元。",
      "source_evidence": ["ev_013"]
    },
    {
      "fact_id": "fact_038",
      "description": "2024-02-20 电话中李海涛认可利息按之前约定计算。",
      "source_evidence": ["ev_014"]
    },
    {
      "fact_id": "fact_039",
      "description": "李海涛在电话中表示暂时无法一次性偿还。",
      "source_evidence": ["ev_013"]
    },
    {
      "fact_id": "fact_040",
      "description": "张建国于 2024-03-01 委托律师向李海涛发送律师函。",
      "source_evidence": ["ev_015"]
    },
    {
      "fact_id": "fact_041",
      "description": "律师函要求李海涛在收到函件后 7 日内偿还剩余本金 180000 元及利息。",
      "source_evidence": ["ev_015"]
    },
    {
      "fact_id": "fact_042",
      "description": "李海涛于 2024-03-03 签收律师函。",
      "source_evidence": ["ev_015"]
    },
    {
      "fact_id": "fact_043",
      "description": "李海涛签收律师函后至 2024-03-15 仍未付款。",
      "source_evidence": ["ev_015"]
    },
    {
      "fact_id": "fact_044",
      "description": "张建国拟起诉要求李海涛偿还剩余本金、利息并承担诉讼费用。",
      "source_evidence": ["ev_001", "ev_002", "ev_015"]
    }
  ]
}
